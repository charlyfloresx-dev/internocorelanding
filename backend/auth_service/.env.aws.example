# --- AWS Production Configuration Template ---
# Rename to .env in your AWS Env Config (e.g. App Runner) or Secrets Manager

# 1. Environment Mode
ENV_MODE=aws

# 2. Database (RDS PostgreSQL 15+)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://admin:YOUR_SECURE_PASSWORD@interno-core-db.cluster-custom.us-east-2.rds.amazonaws.com:5432/auth_db

# 3. Security & Cryptography
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=YOUR_GENERATED_STRONG_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
SELECTION_TOKEN_EXPIRE_MINUTES=5

# 4. Networking & CORS
# The CloudFront URL where the Frontend lives
FRONTEND_URL=https://d1234abcd.cloudfront.net
# AWS Region for Secrets Manager / SSM
AWS_REGION=us-east-2
