{
    "name": "tickets-service",
    "version": "1.0.0",
    "description": "Microservicio de gestión de tickets y trazabilidad operativa.",
    "dependencies": [
        "common",
        "auth-service (local validation)"
    ],
    "infrastructure": {
        "database": "MySQL / PostgreSQL (Compatible)",
        "runtime": "Python 3.11",
        "orchestration": "Docker / K8s",
        "cloud": "AWS (EKS/ECS) / On-Premise"
    },
    "compliance": {
        "multitenancy": "Strict (company_id filtering)",
        "auditability": "AuditBase / TicketHistory",
        "identity": "UUID + Sequence + ReferenceCode"
    }
}