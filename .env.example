# ==================================
# Entorno General
# ==================================
# Opciones: development, production, staging
ENVIRONMENT=development

# ==================================
# Interno Core - Notificaciones (Resend)
# ==================================
# Llave de API de Resend para el envío de correos
CORE_RESEND_API_KEY=your_resend_api_key_here

# ==================================
# Configuración de Base de Datos
# ==================================
DB_ENGINE=postgresql
DB_HOST=interno-db
DB_PORT=5432
DB_NAME=interno_auth
DB_USER=user
DB_PASSWORD=password

# Variables para microservicios individuales
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=interno_auth

# ==================================
# Arquitectura Multi-Tenant
# ==================================
MULTI_TENANT_MODE=True

# ==================================
# Seguridad y Autenticación
# ==================================
JWT_SECRET=DEV_SECRET_KEY_CAMBIAME_EN_PROD_12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================================
# Almacenamiento de Archivos (S3 / MinIO)
# ==================================
S3_ENDPOCORE_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=internocore-bucket

# ==================================
# Servicios Externos (Stripe)
# ==================================
CORE_STRIPE_PUBLIC_KEY=pk_test_...
CORE_STRIPE_SECRET_KEY=sk_test_...
CORE_STRIPE_WEBHOOK_SECRET=whsec_...
CORE_STRIPE_PRODUCT_ID=prod_...

# ==================================
# Banxico API (Currency Service)
# ==================================
CORE_BANXICO_TOKEN=c0a7ca4f35248b6c0f015c867415f6fbfe87dd05a6385f37c38f1a9253443c00
