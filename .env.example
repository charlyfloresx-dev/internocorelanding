# ==================================
# Entorno General
# ==================================
# Opciones: development, production, staging
ENVIRONMENT=development

# ==================================
# Configuración de Base de Datos
# ==================================
# Motor de base de datos a utilizar. Opciones: postgresql, mysql
DB_ENGINE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=internocore_db
DB_USER=admin
DB_PASSWORD=change_this_password

# ==================================
# Arquitectura Multi-Tenant
# ==================================
# Activa o desactiva el modo multi-tenant. Opciones: True, False
MULTI_TENANT_MODE=True

# ==================================
# Seguridad y Autenticación
# ==================================
# Secreto para firmar los JWT. Debe ser una cadena larga y aleatoria.
# En producción, SIEMPRE cargar desde un gestor de secretos.
JWT_SECRET=a_very_secret_and_long_string_that_should_be_changed

# ==================================
# Almacenamiento de Archivos (S3 / MinIO)
# ==================================
# Para AWS S3, dejar S3_ENDPOINT_URL vacío.
# Para MinIO (desarrollo local), apuntar al servicio de MinIO.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=internocore-bucket

# ==================================
# Stripe API Keys (Fase 18)
# ==================================
INT_STRIPE_PUBLIC_KEY=pk_test_...
INT_STRIPE_SECRET_KEY=sk_test_...
INT_STRIPE_WEBHOOK_SECRET=whsec_...
INT_STRIPE_PRODUCT_ID=prod_...
