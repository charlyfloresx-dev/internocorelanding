{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "baseUrl": "./",
    "types": []
  },
  "files": [
    "src/main.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
