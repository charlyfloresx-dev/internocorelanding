  "components": {
    "schemas": {
      "AccessTokenResponse": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "token_type": {
            "type": "string",
            "title": "Token Type",
            "default": "bearer"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "title": "User Id"
          },
          "company_id": {
            "type": "string",
            "format": "uuid",
            "title": "Company Id"
          },
          "group_id": {
            "anyOf": [
              {
                "type": "string",
                "format": "uuid"
              },
              {
                "type": "null"
              }
            ],
            "title": "Group Id"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "permissions": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Permissions",
            "default": []
          },
          "scopes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Scopes",
            "default": []
          },
          "accessible_warehouses": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "default": []
          }
        },
        "type": "object",
        "required": [
          "access_token",
          "user_id",
          "company_id"
        ],
        "title": "AccessTokenResponse",
        "description": "Respuesta final con el JWT de acceso por empresa."
      },
      "ApiMeta": {
        "properties": {
          "trace_id": {
            "type": "string",
            "title": "Trace Id"
          },
          "latency": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Latency"
          }
        },
        "additionalProperties": true,
        "type": "object",
        "title": "ApiMeta"
      },
      "ApiResponse": {
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "success",
              "error"
            ],
            "title": "Status",
            "default": "success"
          },
