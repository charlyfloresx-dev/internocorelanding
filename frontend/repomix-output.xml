import { Component, inject, signal, OnDestroy } from '@angular/core';
import { CommonModule } from '@angular/common';
import { ProductionDataService } from '../../services/production-data.service';
import { Html5QrcodeScanner, Html5QrcodeSupportedFormats } from 'html5-qrcode';
import { ToastService } from '../../services/toast.service';

@Component({
  selector: 'app-work-order-list',
  standalone: true,
  imports: [CommonModule],
  template: `
    <div class="p-6 animate-fade-in">
      <div class="flex justify-between items-center mb-6">
        <h2 class="text-2xl font-bold text-white">Órdenes de Trabajo</h2>
        <button (click)="openScanner()" class="bg-sky-600 hover:bg-sky-500 text-white px-4 py-2 rounded-lg flex items-center gap-2 transition-colors shadow-lg shadow-sky-900/20">
          <i class="fas fa-qrcode"></i> Escanear Orden
        </button>
      </div>

      <!-- Lista de Órdenes -->
      <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden shadow-xl">
        <table class="w-full text-left text-sm text-slate-400">
          <thead class="bg-slate-900 text-slate-200 uppercase font-medium">
            <tr>
              <th class="p-4">Orden</th>
              <th class="p-4">Producto</th>
              <th class="p-4">Progreso</th>
              <th class="p-4">Estado</th>
              <th class="p-4 text-right">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-700">
            @for (order of productionService.activeOrders(); track order.id) {
              <tr class="hover:bg-slate-700/50 transition-colors group">
                <td class="p-4 font-medium text-white group-hover:text-sky-400 transition-colors">{{ order.orderNumber }}</td>
                <td class="p-4">
                  <div class="text-white">{{ order.productName }}</div>
                  <div class="text-xs text-slate-500">{{ order.sku }}</div>
                </td>
                <td class="p-4">
                  <div class="w-full bg-slate-700 rounded-full h-2 mb-1">
                    <div class="bg-sky-500 h-2 rounded-full" [style.width.%]="order.progress"></div>
                  </div>
                  <span class="text-xs">{{ order.progress }}%</span>
                </td>
                <td class="p-4">
                  <span [class]="getStatusClass(order.status)" class="px-2 py-1 rounded text-xs font-bold border border-transparent">
                    {{ order.status }}
                  </span>
                </td>
                <td class="p-4 text-right">
                  <button class="text-slate-400 hover:text-white p-2 hover:bg-slate-600 rounded-full transition-colors"><i class="fas fa-ellipsis-v"></i></button>
                </td>
              </tr>
            } @empty {
              <tr>
                <td colspan="5" class="p-12 text-center text-slate-500">
