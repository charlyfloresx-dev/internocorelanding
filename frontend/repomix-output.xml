import { Component, inject, OnInit, signal } from '@angular/core';
import { CommonModule } from '@angular/common';
import { ProductionDataService } from '../../services/production-data.service';
import { HourlyChartComponent } from '../../components/charts/hourly-chart.component';
import { TrendChartComponent } from '../../components/charts/trend-chart.component';
import { ParetoChartComponent } from '../../components/charts/pareto-chart.component';
import { DowntimeRegisterModalComponent } from './components/downtime-register-modal.component';

export interface WorkOrderDto {
  id: string;
  orderNumber: string;
  customer: string;
  status: string;
  progress: number;
  cost: number;        // <--- Soluciona error 'cost'
  dueDate: string | Date; // <--- Soluciona error 'dueDate'
}

@Component({
  selector: 'app-production-dashboard',
  standalone: true,
  imports: [CommonModule, HourlyChartComponent, TrendChartComponent, ParetoChartComponent, DowntimeRegisterModalComponent],
  templateUrl: './production-dashboard.component.html'
})
export class ProductionDashboardComponent implements OnInit {
  dataService = inject(ProductionDataService);
  Math = Math;
  
  isDowntimeModalOpen = signal(false);

  ngOnInit() {
    this.dataService.loadDashboard();
  }
  
  openDowntimeModal() {
    this.isDowntimeModalOpen.set(true);
  }

  closeDowntimeModal() {
    this.isDowntimeModalOpen.set(false);
  }

  getStatusClass(status: string): string {
    switch (status) {
      case 'Running': return 'bg-sky-500/10 border-sky-500/20 text-sky-500';
      case 'Risk': return 'bg-yellow-500/10 border-yellow-500/20 text-yellow-500';
      case 'Delayed': return 'bg-red-500/10 border-red-500/20 text-red-500';
      default: return 'bg-slate-700 text-slate-400';
    }
  }

  getProgressColor(status: string): string {
    switch (status) {
      case 'Running': return 'bg-sky-500';
      case 'Risk': return 'bg-yellow-500';
      case 'Delayed': return 'bg-red-500';
      default: return 'bg-slate-500';
    }
  }

  getStatusTextClass(status: string): string {
    switch (status) {
      case 'Running': return 'text-sky-500';
      case 'Risk': return 'text-yellow-500';
      case 'Delayed': return 'text-red-500';
      default: return 'text-slate-500';
    }
  }
}
