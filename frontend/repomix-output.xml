               @if (onboarding.state().step < 6) {
                 <button (click)="next()" class="px-6 py-2 rounded-lg bg-green-600 text-white font-bold hover:bg-green-500 shadow-lg shadow-green-900/20 transition-all">
                   Siguiente
                 </button>
               } @else {
                 <button (click)="finish()" class="px-8 py-2 rounded-lg bg-green-500 text-slate-900 font-bold hover:bg-green-400 shadow-lg shadow-green-900/40 transition-all flex items-center gap-2">
