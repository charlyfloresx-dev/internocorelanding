                     <i class="fas fa-magic text-yellow-500"></i> 
                     <span>Simular Escaneo (Dev)</span>
                   </button>
                 </div>
               }
            </div>

            <div class="p-4 bg-slate-800 text-center text-xs text-slate-500 border-t border-slate-700">
              Apunta la cámara al código QR de la orden de trabajo.
            </div>
          </div>
        </div>
      }
    </div>
  `
})
export class WorkOrderListComponent implements OnDestroy {
  productionService = inject(ProductionDataService);
  toast = inject(ToastService);
  
  showScanner = signal(false);
  scannerError = signal<string | null>(null);
  private scanner: Html5QrcodeScanner | null = null;

  constructor() {
    this.productionService.loadWorkOrders();
  }

  getStatusClass(status: string): string {
    switch (status) {
      case 'Running': return 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20';
      case 'Pending': return 'bg-slate-500/10 text-slate-400 border-slate-500/20';
      case 'Delayed': return 'bg-rose-500/10 text-rose-500 border-rose-500/20';
      case 'Risk': return 'bg-amber-500/10 text-amber-500 border-amber-500/20';
      default: return 'bg-slate-500/10 text-slate-500 border-slate-500/20';
    }
  }

  openScanner() {
    this.showScanner.set(true);
    this.scannerError.set(null);

    // Esperamos a que el DOM renderice el div #reader
    setTimeout(() => {
      this.initScanner();
    }, 100);
  }

  closeScanner() {
    if (this.scanner) {
      this.scanner.clear().catch(err => console.warn('Scanner clear warning:', err));
      this.scanner = null;
    }
    this.showScanner.set(false);
  }

  initScanner() {
    // Verificación básica de soporte de medios
    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      const msg = 'Tu navegador no soporta acceso a cámara o no es un contexto seguro (HTTPS/Localhost).';
      console.error('❌ CAMERA ERROR:', msg);
      this.scannerError.set(msg);
      return;
    }

    try {
      this.scanner = new Html5QrcodeScanner(
        "reader",
        { 
          fps: 10, 
          qrbox: { width: 250, height: 250 },
          aspectRatio: 1.0,
          showTorchButtonIfSupported: true,
          formatsToSupport: [ Html5QrcodeSupportedFormats.QR_CODE ]
        },
        /* verbose= */ false
      );

      this.scanner.render(
        (decodedText) => this.handleScanSuccess(decodedText),
        (errorMessage) => {
            // html5-qrcode reporta errores por cada frame fallido, lo cual es normal.
            // Solo nos interesan errores de inicialización o permisos que suelen saltar en el catch o antes.
            // Sin embargo, si el error contiene "Permission", lo capturamos.
            if (errorMessage?.toString().includes("Permission")) {
                console.error('❌ SCANNER PERMISSION ERROR:', errorMessage);
                this.scannerError.set('Permiso de cámara denegado. Revisa la configuración del navegador.');
                this.scanner?.clear();
            }
        }
      );
    } catch (e: any) {
      console.error('❌ SCANNER INIT EXCEPTION:', e);
      this.scannerError.set('Error al iniciar la cámara: ' + (e.message || 'Desconocido'));
    }
  }

  handleScanSuccess(decodedText: string) {
    console.log(`✅ QR DETECTADO: ${decodedText}`);
    this.closeScanner();
    this.toast.success(`Orden identificada: ${decodedText}`, 'Escaneo Exitoso');
    // Aquí conectaríamos con el backend para cargar la orden
  }

  simulateScan() {
    console.warn('⚠️ SIMULANDO ESCANEO (Modo Desarrollo)');
    const mockOrder = 'WO-' + Math.floor(Math.random() * 1000 + 1000);
    this.handleScanSuccess(mockOrder);
  }

  ngOnDestroy() {
    if (this.scanner) {
      this.scanner.clear().catch(() => {});
    }
  }
}
