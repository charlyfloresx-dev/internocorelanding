import { HttpInterceptorFn, HttpResponse, HttpErrorResponse, HttpEvent } from '@angular/common/http';
import { inject } from '@angular/core';
import { map, tap, catchError } from 'rxjs/operators';
import { throwError } from 'rxjs';
import { ApiResponse } from '../models/api.types';
import { ToastService } from '../../services/toast.service';
import { AuthService } from '../../services/auth.service';

// Directiva de Homologación #001: Interceptor Inteligente & Multi-tenant Middleware
export const apiInterceptor: HttpInterceptorFn = (req, next) => {
  const toast = inject(ToastService);
  const auth = inject(AuthService);

  // 1. Cross-Cutting Concern: Multi-tenancy
  // Extract CompanyId from current session state and inject into headers
  // This satisfies the .NET Middleware requirement for TenantResolution
  const currentCompanyId = auth.currentContext()?.companyId;
  
  let modifiedReq = req;
  
  if (currentCompanyId) {
    modifiedReq = req.clone({
      setHeaders: {
        'X-Company-Id': currentCompanyId.toString(),
        'Authorization': `Bearer ${auth.currentContext()?.sessionToken}`
      }
    });
  }

  return next(modifiedReq).pipe(
    map((event: HttpEvent<unknown>) => {
      if (event instanceof HttpResponse) {
        const response = event as HttpResponse<any>;
        const body = response.body as ApiResponse<any>;
        
        // 2. API Protocol Check
        if (body && body.status) {
          if (body.status === 'success') {
            
            // 3. Semantic Feedback Logic
            // GET requests are silent on success (reduce noise)
            // POST, PUT, DELETE, PATCH are "Mutations" and require confirmation
            if (req.method !== 'GET') {
              toast.success(body.message || 'Cambios guardados correctamente');
            }

            // 4. Unwrap Data
            return response.clone({ body: body.data });

          } else {
             // Logic Error from Backend (e.g. "Stock Insufficient")
             throw new Error(body.message || 'Error desconocido en la operación');
          }
        }
      }
      return event;
    }),
    catchError((error) => {
      console.error('[API Interceptor Caught]', error);
      
      let errorTitle = 'Error de Comunicación';
      let errorMessage = 'No se pudo conectar con el servidor.';

      if (error instanceof HttpErrorResponse) {
        errorTitle = `Error ${error.status}`;
        errorMessage = error.error?.message || error.message || 'Fallo en el servicio remoto.';
        
        if (error.status === 401) {
          errorTitle = 'Sesión Expirada';
          errorMessage = 'Por favor, inicie sesión nuevamente.';
          auth.logout(); // Force logout on 401
        }
        if (error.status === 403) {
          errorTitle = 'Acceso Denegado';
          errorMessage = 'No tiene permisos para realizar esta acción en este entorno (Tenant).';
        }
      } else if (error instanceof Error) {
        errorTitle = 'Error de Operación';
        errorMessage = error.message;
      }

      toast.error(errorMessage, errorTitle);
      
      return throwError(() => error);
    })
  );
};
</file>

