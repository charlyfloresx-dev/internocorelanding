            }
          </tbody>
        </table>
      </div>

      <!-- Modal Escáner -->
      @if (showScanner()) {
        <div class="fixed inset-0 bg-black/90 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
