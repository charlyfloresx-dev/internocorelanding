                   </div>
                   <div>
                     <label class="block text-slate-400 text-xs font-bold mb-2">Industria Principal</label>
                     <select [(ngModel)]="data.industry" (ngModelChange)="updateServiceData()" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-white focus:border-green-500 outline-none">
                       <option value="">Seleccionar...</option>
                       <option>Automotriz</option>
                       <option>Metalmecánica</option>
                       <option>Plásticos</option>
                       <option>Alimentos</option>
                     </select>
                   </div>
                </div>
                <!-- Optional -->
                <div class="space-y-5">
                   <h3 class="text-sky-400 font-bold text-xs uppercase tracking-widest border-b border-sky-500/30 pb-2">Opcionales</h3>
                   <div>
                     <label class="block text-slate-400 text-xs font-bold mb-2">Código de Sitio (ERP)</label>
                     <input type="text" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-white focus:border-sky-500 outline-none transition-colors" placeholder="Ej. ST-MX-001">
                   </div>
                   <div>
                     <label class="block text-slate-400 text-xs font-bold mb-2">Tamaño de Fuerza Laboral</label>
                     <select [(ngModel)]="data.employeesCount" (ngModelChange)="updateServiceData()" class="w-full bg-slate-900 border border-slate-700 rounded-lg p-3 text-white focus:border-sky-500 outline-none">
                       <option value="">Seleccionar...</option>
                       <option>1 - 50</option>
                       <option>51 - 200</option>
                       <option>200+</option>
                     </select>
                   </div>
                </div>
              </div>
            }

            <!-- STEP 2: STRUCTURE -->
            @if (onboarding.state().step === 2) {
              <div class="flex flex-col h-full animate-fade-in">
                <div class="flex items-center justify-between mb-4">
                  <h3 class="text-slate-300 font-bold text-sm">Líneas de Producción</h3>
                  <button (click)="addLine()" class="text-green-500 hover:text-green-400 text-sm font-bold flex items-center gap-2 px-3 py-1 rounded hover:bg-green-500/10 transition-colors">
                    <i class="fa-solid fa-plus"></i> Agregar Línea
                  </button>
                </div>
                
                <div class="flex-1 overflow-y-auto space-y-2 pr-2 custom-scrollbar">
                  @if (lines().length === 0) {
                    <div class="text-center py-12 border-2 border-dashed border-slate-700 rounded-lg text-slate-500">
                      <i class="fa-solid fa-industry text-2xl mb-2"></i>
                      <p>No hay líneas configuradas aún.</p>
                    </div>
                  }
                  @for (line of lines(); track $index) {
                    <div class="flex items-center gap-3 p-3 bg-slate-900 border border-slate-700 rounded-lg group hover:border-slate-600 transition-colors">
                      <div class="w-8 h-8 rounded bg-slate-800 flex items-center justify-center text-slate-500 font-mono text-xs">{{ $index + 1 }}</div>
                      <input type="text" [(ngModel)]="line.name" class="flex-1 bg-transparent border-none text-white placeholder-slate-600 focus:ring-0" placeholder="Nombre de la Línea (Ej. Línea A)">
                      <select class="bg-slate-800 border-none text-xs text-slate-400 rounded py-1 px-2">
                        <option>Discreta</option>
                        <option>Procesos</option>
                      </select>
                      <button (click)="removeLine($index)" class="w-8 h-8 flex items-center justify-center text-slate-600 hover:text-red-500 hover:bg-red-500/10 rounded transition-colors">
                        <i class="fa-solid fa-trash"></i>
                      </button>
                    </div>
                  }
                </div>
              </div>
            }

            <!-- STEP 3: CATALOGS -->
            @if (onboarding.state().step === 3) {
              <div class="animate-fade-in">
