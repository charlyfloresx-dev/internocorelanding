             <div class="flex gap-4">
               <button (click)="prev()" [disabled]="onboarding.state().step === 1" class="px-6 py-2 rounded-lg bg-slate-800 text-white font-medium hover:bg-slate-700 disabled:opacity-0 disabled:pointer-events-none transition-all">
                 Atrás
