})
export class DowntimeRegisterModalComponent implements OnInit {
  prodService = inject(ProductionDataService);
  fb: FormBuilder = inject(FormBuilder);
  
  close = output<void>();

  form = this.fb.group({
    lineId: ['ENS-01', Validators.required],
    workOrderId: [''],
    issueId: ['', Validators.required],
    description: ['', Validators.required],
    requestNumber: [1] // Mock ID
  });

  ngOnInit() {
    this.prodService.loadIssues();
  }

  async submit() {
    if (this.form.invalid) return;
    const success = await this.prodService.registerDowntime(this.form.value as any);
    if (success) {
      this.close.emit();
    }
  }
}
