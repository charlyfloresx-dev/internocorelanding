import { HttpInterceptorFn, HttpRequest, HttpHandlerFn } from '@angular/common/http';

export const authInterceptor: HttpInterceptorFn = (req: HttpRequest<unknown>, next: HttpHandlerFn) => {
  let token = '';
  let companyId = '';
  
  // 1. Intentar obtener el contexto completo de la sesión
  const storedCtx = localStorage.getItem('interno_auth_ctx');
  
  if (storedCtx) {
    try {
      const ctx = JSON.parse(storedCtx);
      token = ctx.sessionToken;
      companyId = ctx.companyId; // Extraemos el ID de la empresa activa
    } catch (error) {
      console.error('Error al parsear el contexto de autenticación en el interceptor:', error);
    }
  }

  // 2. Si no hay sesión (token de usuario), buscar el token de selección (Fase de Handshake)
  if (!token) {
    token = localStorage.getItem('selection_token') || '';
  }

  // 3. Si existe un token, clonamos la petición inyectando las cabeceras
  if (token) {
    // Configuramos las cabeceras base
    const headersConfig: { [header: string]: string } = {
      'Authorization': `Bearer ${token}`
    };

    // Si tenemos un companyId (estamos en modo "authenticated"), lo enviamos
    // Esto es lo que permite el Multitenancy en el Backend
    if (companyId) {
      headersConfig['X-Company-Id'] = companyId.toString();
    }

    const authReq = req.clone({
      setHeaders: headersConfig
    });

    return next(authReq);
  }

  // Si no hay token, la petición sigue su curso normal (ej. para el login inicial)
  return next(req);
};
</file>

<file path="src/app/core/interceptors/tenant.interceptor.ts">
import { HttpInterceptorFn } from '@angular/common/http';
import { inject } from '@angular/core';
import { AuthService } from '../../services/auth.service';

/**
 * Interceptor que añade el ID de la empresa (tenant) a las cabeceras de las peticiones salientes.
 * Extrae el `companyId` del `AuthService` y lo añade como el header `X-Company-ID`.
 * Esto es crucial para que el backend multi-tenant sepa en qué contexto de cliente
 * se está realizando la operación, según la especificación del README del backend.
 */
export const tenantInterceptor: HttpInterceptorFn = (req, next) => {
  const authService = inject(AuthService);
  const companyId = authService.selectedCompanyId(); // Obtiene el valor del signal

  // Si hay una empresa seleccionada, clonamos la petición y añadimos el header.
  if (companyId) {
    const clonedReq = req.clone({
      setHeaders: {
        'X-Company-ID': companyId.toString()
      }
    });
    return next(clonedReq);
  }

  // Si no hay empresa seleccionada, la petición continúa sin modificarse.
  return next(req);
};
</file>

