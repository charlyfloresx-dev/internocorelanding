               <div id="reader" class="w-full h-full"></div>

               <!-- Overlay de Error / Fallback -->
               @if (scannerError()) {
                 <div class="absolute inset-0 flex flex-col items-center justify-center bg-slate-900/95 p-8 text-center z-20">
                   <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mb-4">
