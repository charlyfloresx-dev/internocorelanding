      <!-- Main Content -->
      <div class="flex-1 flex flex-col items-center justify-center p-6 relative overflow-hidden">
        
        <!-- Progress Bar Background -->
        <div class="absolute top-0 left-0 w-full h-1 bg-slate-900">
           <div class="h-full bg-green-500 transition-all duration-700 ease-out shadow-[0_0_10px_rgba(34,197,94,0.5)]" 
                [style.width.%]="(onboarding.state().step / 6) * 100"></div>
        </div>

        <div class="w-full max-w-4xl flex flex-col gap-6 animate-fade-in-up">
          
          <!-- Step Indicator -->
          <div class="flex items-end justify-between px-2">
            <div>
              <h1 class="text-3xl font-bold text-white mb-1">{{ getStepTitle() }}</h1>
              <p class="text-slate-400 text-sm">{{ getStepDescription() }}</p>
            </div>
