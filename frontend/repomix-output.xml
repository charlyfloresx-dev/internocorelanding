import { Injectable, inject, signal } from '@angular/core';
import { ApiSimulationService } from './api-simulation.service';
import { AuthService } from './auth.service';
import { InventoryItemDto, CreateInventoryItemCommand, AdjustStockCommand, ProductCategory, Partnership, Warehouse, WarehouseType, WarehouseGroup, Concept, InventoryDocument, CreateDocumentCommand } from '../core/models/api.types';
import { ToastService } from './toast.service';

@Injectable({
  providedIn: 'root'
})
export class InventoryService {
  private api = inject(ApiSimulationService);
  private auth = inject(AuthService);
  private toast = inject(ToastService);

  // State
  items = signal<InventoryItemDto[]>([]);
  documents = signal<InventoryDocument[]>([]);
  
  // Catalogs
  categories = signal<ProductCategory[]>([]);
  partnerships = signal<Partnership[]>([]);
  warehouses = signal<Warehouse[]>([]);
  concepts = signal<Concept[]>([]);
  
  // New Catalogs for Warehouse Management
  warehouseTypes = signal<WarehouseType[]>([]);
  warehouseGroups = signal<WarehouseGroup[]>([]);
  
  loading = signal<boolean>(false);

  loadItems() {
    const companyId = this.auth.currentContext()?.companyId;
    if (!companyId) return;

    this.loading.set(true);
    this.api.getInventoryItems(companyId).subscribe({
      next: (res) => {
        this.items.set(res.data);
        this.loading.set(false);
      },
      error: () => this.loading.set(false)
    });
  }

  loadDocuments() {
    const companyId = this.auth.currentContext()?.companyId;
    if (!companyId) return;

    this.loading.set(true);
    this.api.getDocuments(companyId).subscribe({
      next: (res) => {
        this.documents.set(res.data);
        this.loading.set(false);
      },
      error: () => this.loading.set(false)
    });
  }

  loadCatalogs() {
    const companyId = this.auth.currentContext()?.companyId;
    if (!companyId) return;

    this.api.getProductCategories().subscribe(res => this.categories.set(res.data));
    this.api.getPartnerships().subscribe(res => this.partnerships.set(res.data));
    this.api.getWarehouses(companyId).subscribe(res => this.warehouses.set(res.data));
    this.api.getConcepts().subscribe(res => this.concepts.set(res.data));
  }

  loadWarehouseCatalogs() {
    this.api.getWarehouseTypes().subscribe(res => this.warehouseTypes.set(res.data));
    this.api.getWarehouseGroups().subscribe(res => this.warehouseGroups.set(res.data));
  }

  createItem(cmd: CreateInventoryItemCommand): Promise<boolean> {
    const companyId = this.auth.currentContext()?.companyId;
    if (!companyId) return Promise.resolve(false);

    return new Promise((resolve) => {
      this.api.createInventoryItem(companyId, cmd).subscribe({
        next: () => {
          this.loadItems(); // Refresh list
          resolve(true);
        },
        error: (err) => {
          this.toast.error(err.message);
          resolve(false);
        }
      });
    });
  }

  adjustStock(cmd: AdjustStockCommand): Promise<boolean> {
    const companyId = this.auth.currentContext()?.companyId;
    if (!companyId) return Promise.resolve(false);

    return new Promise((resolve) => {
      this.api.adjustStock(companyId, cmd).subscribe({
        next: () => {
          this.loadItems(); // Refresh list
          resolve(true);
        },
        error: (err) => {
          this.toast.error(err.message);
          resolve(false);
        }
      });
    });
  }

  createDocument(cmd: CreateDocumentCommand): Promise<boolean> {
    const companyId = this.auth.currentContext()?.companyId;
    if (!companyId) return Promise.resolve(false);

    return new Promise((resolve) => {
      this.api.createDocument(companyId, cmd).subscribe({
        next: () => {
          this.loadDocuments();
          // Also reload items since stock might have changed
          this.loadItems(); 
          resolve(true);
        },
        error: (err) => {
          this.toast.error(err.message);
          resolve(false);
        }
      });
    });
  }
}
