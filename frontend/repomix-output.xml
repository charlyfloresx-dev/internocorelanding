})
export class OnboardingWizardComponent implements OnInit {
  auth = inject(AuthService);
  onboarding = inject(OnboardingService);
  
  // Local binding for inputs
  data = {
    companyName: '',
    industry: '',
    employeesCount: ''
  };

  lines = signal([{ name: 'Linea 01' }]);
  downtimeReasons = signal([
    { name: 'Falla Mecánica' },
    { name: 'Falla Eléctrica' },
    { name: 'Falta de Material' },
    { name: 'Ausentismo' },
    { name: 'Ajuste de Máquina' }
  ]);

  ngOnInit() {
    this.onboarding.reset();
    // Pre-fill if we have company name
    const currentName = this.auth.activeCompany()?.name;
    if (currentName) {
      this.data.companyName = currentName;
      this.updateServiceData();
    }
  }

  updateServiceData() {
    this.onboarding.updateState(this.data);
  }

  getStepTitle() {
    switch(this.onboarding.state().step) {
      case 1: return 'Identidad';
      case 2: return 'Estructura';
      case 3: return 'Catálogos';
      case 4: return 'Equipo';
      case 5: return 'Primera Orden';
      case 6: return 'Resumen';
      default: return '';
    }
  }

  getStepDescription() {
    switch(this.onboarding.state().step) {
      case 1: return 'Define los datos básicos de tu planta.';
      case 2: return 'Crea las líneas de producción que vas a monitorear.';
      case 3: return 'Estandariza los motivos de tiempo muerto.';
      case 4: return 'Confirma tu perfil de administrador.';
      case 5: return 'Opcional: Crea una orden para probar el sistema.';
      case 6: return 'Revisa y confirma la configuración.';
      default: return '';
    }
  }

  next() {
    this.onboarding.nextStep();
  }

  prev() {
    this.onboarding.prevStep();
  }

  skip() {
    if (this.onboarding.state().step === 5) this.next();
    else this.finish(); 
  }

  finish() {
    this.onboarding.submitOnboarding();
  }

  addLine() {
    this.lines.update(l => [...l, { name: `Linea 0${l.length + 1}` }]);
  }

  removeLine(index: number) {
    this.lines.update(l => l.filter((_, i) => i !== index));
  }

  addReason() {
    this.downtimeReasons.update(r => [...r, { name: 'Nuevo Motivo' }]);
  }

  removeReason(index: number) {
    this.downtimeReasons.update(r => r.filter((_, i) => i !== index));
  }
}
