import { Injectable, signal, inject, computed, effect } from '@angular/core';
import { Router } from '@angular/router';
import { HttpClient } from '@angular/common/http';
import { User, SessionContext, UserCompanyAccess } from '../core/models/api.types';
import { NavigationService } from './navigation.service';
import { tap } from 'rxjs/operators';

@Injectable({
  providedIn: 'root'
})
export class AuthService {
  private apiUrl = '/api';
  private http = inject(HttpClient);
  private router = inject(Router);
  private navService = inject(NavigationService);

  currentUser = signal<User | null>(null);
  availableAccesses = signal<UserCompanyAccess[]>([]);
  currentContext = signal<SessionContext | null>(null);
  authStep = signal<'guest' | 'handshake' | 'authenticated'>('guest');
  isLoading = signal<boolean>(false);

  isAuthenticated = computed(() => this.authStep() === 'authenticated');
  selectedCompanyId = computed(() => this.currentContext()?.companyId || null);
  activeRole = computed(() => this.currentContext()?.role || null);
  activeCompany = computed(() => {
    const ctx = this.currentContext();
    return this.availableAccesses().find(a => String(a.company.id) === String(ctx?.companyId))?.company;
  });

  constructor() {
    this.restoreSession();
    effect(() => {
      const ctx = this.currentContext();
      if (ctx && this.currentUser()) {
        localStorage.setItem('interno_auth_ctx', JSON.stringify(ctx));
        localStorage.setItem('interno_auth_user', JSON.stringify(this.currentUser()));
        localStorage.setItem('interno_auth_accesses', JSON.stringify(this.availableAccesses()));
      }
    });
  }

  private restoreSession() {
    try {
      const savedCtx = localStorage.getItem('interno_auth_ctx');
      if (savedCtx) {
        this.currentContext.set(JSON.parse(savedCtx));
        this.currentUser.set(JSON.parse(localStorage.getItem('interno_auth_user') || 'null'));
        this.availableAccesses.set(JSON.parse(localStorage.getItem('interno_auth_accesses') || '[]'));
        this.authStep.set('authenticated');
      } else {
        this.authStep.set('guest');
      }
    } catch (e) { this.logout(); }
  }

  login(credentials: { email?: string; password?: string }) {
    this.isLoading.set(true);
    return this.http.post<any>(`${this.apiUrl}/v1/auth/login`, credentials)
      .pipe(
        tap({
          next: (response) => {
            // EL CAMBIO DEFINITIVO: Intentamos leer de 'data' y si no, del objeto raíz.
            // Según tu captura image_7a4516.jpg, el token está directo en el objeto que imprimiste.
            const apiData = response.data ? response.data : response; 

            if (!apiData || !apiData.selection_token) {
              console.error('ERROR: No se encontró selection_token en el objeto:', apiData);
              this.isLoading.set(false);
              return;
            }

            localStorage.setItem('selection_token', apiData.selection_token);

            this.currentUser.set({
              id: apiData.user_id,
              email: credentials.email || '',
              firstName: credentials.email?.split('@')[0] || 'Usuario',
              avatar: `https://ui-avatars.com/api/?name=${apiData.user_id}`
            } as any);

            const formattedAccesses: UserCompanyAccess[] = (apiData.companies || []).map((c: any) => ({
              company: {
                id: c.company_id,
                name: c.company_name,
                logo: c.logo,
                isNew: c.is_new
              },
              role: {
                name: c.role_names?.[0] || 'admin',
                permissions: ['admin'] 
              }
            }));

            this.availableAccesses.set(formattedAccesses);
            
            // Esto es lo que quita la pantalla de "Processing Request"
            this.authStep.set('handshake');
            this.isLoading.set(false);
          },
          error: (err) => {
            console.error('Error en petición:', err);
            this.isLoading.set(false);
          }
        })
      );
  }

  selectCompany(companyId: string | number) {
    const access = this.availableAccesses().find(a => String(a.company.id) === String(companyId));
    this.currentContext.set({
      sessionToken: localStorage.getItem('selection_token') || '',
      companyId: companyId.toString(),
      role: access?.role || { name: 'admin' } as any,
      permissions: ['admin']
    });
    this.authStep.set('authenticated');
    this.router.navigate(['/dashboard']);
  }

  switchCompany() {
    this.currentContext.set(null);
    this.authStep.set('handshake');
    this.router.navigate(['/login']);
  }

  logout() {
    localStorage.clear();
    this.authStep.set('guest');
    this.currentContext.set(null);
    this.router.navigate(['/login']);
  }
}
