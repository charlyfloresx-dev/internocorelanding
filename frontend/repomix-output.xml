          </div>

          <!-- Wizard Card -->
          <div class="bg-slate-800 rounded-2xl border border-slate-700 shadow-2xl p-8 min-h-[400px] flex flex-col relative overflow-hidden">
            
            @if (onboarding.loading()) {
